#!/bin/bash
set -euo pipefail

push_tag() {
    TAG="$1-date-$(date "+%Y%m%d%H%M%S")-$(echo $((RANDOM%10000)))"
    if [ -n "${2:-}" ]; then
        TAG="$TAG-$2"
    fi
    git tag "$TAG" -m "$TAG"
    git push origin "$TAG"
    git tag -d "$TAG"
    CURRENT_BRANCH=$(git symbolic-ref --short HEAD)
    COMMIT=$(git log -n 1 --pretty=format:"%h")
    echo "Pushed tag '$TAG' to branch '$CURRENT_BRANCH' at commit '$COMMIT'."
}

TAG_START="trigger-build"
TAG_BUMP="bump"
DEFAULT_TAG_BUMP="patch"
DEFAULT_TAG="$TAG_START-$TAG_BUMP-$DEFAULT_TAG_BUMP"

# Parse arguments
BETA_BUILD=false
SKIP_SWIFTLINT=false
VERSION_BUMP=""

while [[ $# -gt 0 ]]; do
    case $1 in
        --beta)
            BETA_BUILD=true
            shift
            ;;
        --skip-swiftlint)
            SKIP_SWIFTLINT=true
            shift
            ;;
        patch|minor|major)
            VERSION_BUMP="$1"
            shift
            ;;
        *)
            echo "Invalid argument. Usage: $0 [patch|minor|major] [--beta] [--skip-swiftlint]"
            exit 1
            ;;
    esac
done

# Set tag prefix based on beta flag
if [ "$BETA_BUILD" = true ]; then
    TAG_START="trigger-beta-build"
fi

# Set version bump (default to patch)
if [ -z "$VERSION_BUMP" ]; then
    VERSION_BUMP="$DEFAULT_TAG_BUMP"
fi

TAG="$TAG_START-$TAG_BUMP-$VERSION_BUMP"
TAG_OPTIONS=""
if [ "$SKIP_SWIFTLINT" = true ]; then
    TAG_OPTIONS="skip-swiftlint"
fi

if [ "$TAG" != "$DEFAULT_TAG" ] || [ -n "$TAG_OPTIONS" ]; then
    if [ -n "$TAG_OPTIONS" ]; then
        read -p "Are you sure you want to push tag '$TAG' with options '$TAG_OPTIONS'? (y/n): " choice
    else
        read -p "Are you sure you want to push tag '$TAG'? (y/n): " choice
    fi
    if [ "$choice" != "y" ]; then
        echo "Operation canceled."
        exit 0
    fi
fi

push_tag "$TAG" "$TAG_OPTIONS"
